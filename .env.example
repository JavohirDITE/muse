# Copy to .env. `docker compose up -d` provides Postgres on :5434.
DATABASE_URL="postgresql://muse:muse@localhost:5434/muse?schema=public"

# 32+ char random string. Generate: `openssl rand -base64 32`
AUTH_SECRET="change-me"

# Optional — leave empty to use the built-in mock model (no key required).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
